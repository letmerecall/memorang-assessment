# Required — get a key at https://openrouter.ai/keys
OPENAI_API_KEY=

# Optional overrides (defaults work for Docker Compose)
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4.1
OPENAI_MCQ_MODEL=openai/gpt-4o-mini

# Optional — CopilotKit public license key (not required for local dev)
# NEXT_PUBLIC_COPILOTKIT_PUBLIC_LICENSE_KEY=

# Local host-based dev only (Docker Compose sets these automatically)
# DATABASE_URL=postgresql://memorang:memorang@localhost:5432/memorang
# AGENT_URL=http://localhost:8123
