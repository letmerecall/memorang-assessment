# Copy to .env and fill in values:
#   cp .env.example .env
#
# Used by the Python agent (run from agent/). Next.js API routes use the
# AGENT_URL default (http://localhost:8123) unless you also set it in
# frontend/.env.local.

# Required — OpenRouter API key (https://openrouter.ai/keys)
OPENAI_API_KEY=

# LLM endpoint (OpenRouter-compatible OpenAI API)
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4.1

# Postgres — matches docker-compose.yml
DATABASE_URL=postgresql://memorang:memorang@localhost:5432/memorang

# FastAPI agent URL (Next.js proxy targets this)
AGENT_URL=http://localhost:8123

# Optional — CopilotKit public license key (frontend only)
# NEXT_PUBLIC_COPILOTKIT_PUBLIC_LICENSE_KEY=
